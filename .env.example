# ============================================================
# 🚀 Brikes Maker Advertisement - Advance Super v1.0.0
# Environment Configuration Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp env.example .env
#   2. Fill in all required values (marked with REQUIRED)
#   3. Never commit .env to version control
#   4. Keep secrets secure and rotate regularly
# ============================================================

# ------------------------------------------------------------
# 🔧 APP SETTINGS
# ------------------------------------------------------------
VITE_APP_NAME="Brikes Maker Advertisement"
VITE_APP_VERSION="1.0.0"
VITE_APP_ENV="development"         # development | staging | production
VITE_APP_TIER="advanced"                # free | advanced | enterprise

# Advanced Mode Toggle
VITE_ADVANCED_MODE=true
VITE_ENABLE_ADVANCED_FEATURES=true

# ------------------------------------------------------------
# 🔐 AUTHENTICATION (OAuth 2.0)
# ------------------------------------------------------------
# Google OAuth - https://console.cloud.google.com
VITE_GOOGLE_OAUTH_ID=              # REQUIRED - your_google_client_id
VITE_GOOGLE_OAUTH_SECRET=          # REQUIRED - your_google_client_secret

# GitHub OAuth - https://github.com/settings/developers
VITE_GITHUB_OAUTH_ID=              # REQUIRED - your_github_client_id
VITE_GITHUB_OAUTH_SECRET=          # REQUIRED - your_github_client_secret

# Microsoft OAuth - https://portal.azure.com
VITE_MICROSOFT_OAUTH_ID=           # OPTIONAL
VITE_MICROSOFT_OAUTH_SECRET=       # OPTIONAL

# OAuth Redirect URI (must match provider settings exactly)
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# ------------------------------------------------------------
# 🔑 JWT & SESSION SECURITY
# ------------------------------------------------------------
VITE_JWT_SECRET=                   # REQUIRED - min 32 chars, random string
VITE_JWT_EXPIRY=15m                # Access token expiry
VITE_REFRESH_TOKEN_EXPIRY=7d       # Refresh token expiry
VITE_SESSION_TIMEOUT=3600000       # Session timeout in ms (1 hour)

# ------------------------------------------------------------
# 🔒 SECURITY SETTINGS
# ------------------------------------------------------------
VITE_ENCRYPTION_KEY=               # REQUIRED - 32 char AES-256 key
VITE_REQUIRE_HTTPS=false           # Set true in production
VITE_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------
# 🌐 API CONFIGURATION
# ------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3001/api
VITE_API_TIMEOUT=30000             # 30 seconds
VITE_API_RETRY_COUNT=3
VITE_RATE_LIMIT_PER_MINUTE=100

# ------------------------------------------------------------
# 🔥 FIREBASE CONFIGURATION (if used)
# ------------------------------------------------------------
VITE_FIREBASE_API_KEY=             # OPTIONAL
VITE_FIREBASE_AUTH_DOMAIN=         # OPTIONAL
VITE_FIREBASE_PROJECT_ID=          # OPTIONAL
VITE_FIREBASE_STORAGE_BUCKET=      # OPTIONAL
VITE_FIREBASE_MESSAGING_SENDER_ID= # OPTIONAL
VITE_FIREBASE_APP_ID=              # OPTIONAL

# ------------------------------------------------------------
# 📊 ANALYTICS & MONITORING
# ------------------------------------------------------------
VITE_ANALYTICS_KEY=                # OPTIONAL - Analytics provider key
VITE_ERROR_TRACKING_KEY=           # OPTIONAL - Sentry/Bugsnag DSN
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true

# ------------------------------------------------------------
# ✨ FEATURE FLAGS (Advanced Features)
# ------------------------------------------------------------
FEATURE_2FA=true
FEATURE_TEAM_COLLABORATION=true
FEATURE_API_ACCESS=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_AI_GENERATION=true
FEATURE_CUSTOM_BRANDING=true
FEATURE_PRIORITY_SUPPORT=true
FEATURE_EXPORT_HD=true
FEATURE_BULK_OPERATIONS=true
FEATURE_ADVANCED_TARGETING=true

# ------------------------------------------------------------
# 💳 SUBSCRIPTION (Stripe or similar)
# ------------------------------------------------------------
VITE_STRIPE_PUBLIC_KEY=            # OPTIONAL
VITE_ADVANCED_PLAN_ID=                  # OPTIONAL
VITE_ENTERPRISE_PLAN_ID=           # OPTIONAL

# ============================================================
# ⚠️  PRODUCTION CHECKLIST (uncomment when deploying)
# ============================================================
# VITE_APP_ENV=production
# VITE_REQUIRE_HTTPS=true
# VITE_CORS_ALLOWED_ORIGINS=https://yourdomain.com
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# ============================================================
