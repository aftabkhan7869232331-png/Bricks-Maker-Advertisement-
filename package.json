{
  "name": "bricks-maker-advertisement",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx backend/server.ts",
    "dev:frontend": "vite frontend --config frontend/vite.config.ts",
    "dev:backend": "tsx backend/server.ts",
    "build": "tsc -b && vite build frontend --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "typecheck": "tsc -b",
    "wan:install": "powershell -ExecutionPolicy Bypass -File scripts/install-wan21.ps1",
    "wan:check": "node scripts/check-wan21.js",
    "requirements:update": "python scripts/update-requirements.py"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@huggingface/inference": "^4.13.20",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "framer-motion": "^12.42.0",
    "i18next": "^26.3.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "recharts": "^3.9.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
