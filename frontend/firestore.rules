rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /campaigns/{document} {
      allow read, write: if true;
    }
    match /projects/{document} {
      allow read, write: if true;
    }
    match /support_tickets/{document} {
      allow read, write: if true;
    }
    match /faqs/{document} {
      allow read, write: if true;
    }
    match /feedback/{document} {
      allow read, write: if true;
    }
  }
}
